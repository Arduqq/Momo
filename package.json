{
  "name": "momo",
  "private": true,
  "version": "0.0.1",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "npm run build:electron && concurrently --kill-others -n vite,electron -c blue,green \"vite\" \"wait-on http://localhost:5173 && VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build:electron": "tsc -p tsconfig.electron.json && cp electron/preload.cjs dist-electron/",
    "build": "npm run build:electron && tsc -p tsconfig.app.json && vite build",
    "dist:mac": "npm run build && electron-builder --mac --publish never",
    "release:mac": "npm run build && electron-builder --mac --publish always",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.momo.research",
    "productName": "Momo",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "asarUnpack": [
      "dist-electron/preload.cjs"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "darkModeSupport": true
    },
    "publish": {
      "provider": "github",
      "owner": "Arduqq",
      "repo": "Momo"
    },
    "dmg": {
      "title": "Momo",
      "iconSize": 128,
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "dependencies": {
    "axios": "^1.15.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.8.0",
    "pdfjs-dist": "^5.6.205",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-textarea-autosize": "^8.5.9",
    "tldraw": "^4.5.9"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/lodash.isequal": "^4.5.8",
    "@types/lodash.isequalwith": "^4.4.9",
    "@types/lodash.throttle": "^4.1.9",
    "@types/lodash.uniq": "^4.5.9",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "tsc-watch": "^7.2.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^9.0.5"
  }
}
